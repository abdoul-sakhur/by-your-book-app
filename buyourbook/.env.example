# =============================================================================
# BuyOurBook — Variables d'environnement
# =============================================================================
# En production (Coolify), définir ces variables dans l'interface Coolify
# NE PAS commiter le fichier .env

# --- Application ---
APP_NAME=BuyOurBook
APP_ENV=local                    # Production: production
APP_KEY=                         # Généré par: php artisan key:generate
APP_DEBUG=true                   # Production: false
APP_TIMEZONE=Africa/Abidjan
APP_URL=http://localhost         # Production: https://votre-domaine.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# --- Logs ---
LOG_CHANNEL=stack                # Production: stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                  # Production: warning

# --- Base de données ---
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# --- Session ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Services ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=

# --- Redis (optionnel) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail ---
MAIL_MAILER=log                  # Production: smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1             # Production: smtp.votre-provider.com
MAIL_PORT=2525                   # Production: 587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="contact@buyyourbook.ci"
MAIL_FROM_NAME="${APP_NAME}"

# --- Vite ---
VITE_APP_NAME="${APP_NAME}"
