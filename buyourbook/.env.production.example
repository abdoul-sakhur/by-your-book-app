# =============================================================================
# BuyOurBook — Variables d'environnement PRODUCTION (VPS Hostinger)
# =============================================================================
# ⚠  CE FICHIER EST UN MODÈLE — copier en .env sur le serveur puis remplir
# ⚠  NE JAMAIS commiter le .env réel (il est dans .gitignore)
#
# Sur le VPS :
#   cp .env.production.example .env
#   nano .env   (ou vim .env)
#   # remplir les valeurs marquées ← À CHANGER
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=BuyYourBook
APP_ENV=production
APP_KEY=                            # ← À GÉNÉRER :  php artisan key:generate --show
APP_DEBUG=false
APP_TIMEZONE=Africa/Abidjan
APP_URL=http://187.127.232.219      # ← Mettre le domaine si disponible : https://buyyourbook.ci

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_CI

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ─── Logs ────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stderr                  # stderr = logs visibles via  docker logs buyourbook
LOG_LEVEL=warning                   # warning en prod (error, critical, alert, emergency remontent aussi)

# ─── Base de données SQLite ───────────────────────────────────────────────────
DB_CONNECTION=sqlite
# Pas besoin de DB_HOST/DB_PORT/DB_DATABASE — SQLite = fichier local dans le volume

# ─── Session & Cache (stockés en SQLite via tables migrées) ──────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null                 # ← mettre le domaine si HTTPS : .buyyourbook.ci

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public              # ← IMPORTANT : nécessaire pour storage:link
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=byb_

# ─── Mail SMTP ────────────────────────────────────────────────────────────────
# Option 1 — Brevo (ex-Sendinblue) : gratuit 300 mails/jour
# Option 2 — Mailgun, Postmark, etc.
MAIL_MAILER=smtp
# MAIL_SCHEME → ne pas définir pour STARTTLS (port 587) ; mettre "smtps" pour SSL (port 465)
MAIL_HOST=smtp-relay.brevo.com      # ← adapter à votre fournisseur SMTP
MAIL_PORT=587
MAIL_USERNAME=                      # ← votre login SMTP
MAIL_PASSWORD=                      # ← votre mot de passe SMTP
MAIL_FROM_ADDRESS="contact@buyyourbook.ci"
MAIL_FROM_NAME="BuyYourBook"

# ─── Vite (frontend buildé, variable exposée à la blade) ────────────────────
VITE_APP_NAME="${APP_NAME}"
